# UniGest demo environment
#
# Use this profile for a web demo/pitch environment only.
# It bypasses auth in the web app and uses demo users/role switcher.

NODE_ENV=development
NEXT_PUBLIC_DEMO_MODE=true

# Web/API URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3000
API_PORT=3001

# Supabase placeholders for demo rendering.
# Replace these with a staging Supabase project if you want API-backed demo data.
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role
SUPABASE_FUNCTIONS_URL=https://placeholder.supabase.co/functions/v1

# Mobile demo/dev placeholders
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=placeholder

# Optional integrations disabled by default in demo
SENTRY_DSN=
RESEND_API_KEY=
RESEND_FROM=noreply@unigest.fr
REQUIRE_MFA=false

# Storage bucket names
SUPABASE_STORAGE_BUCKET_DOCUMENTS=documents
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
